#!/bin/bash
echo "⚙️   Started pre-commit checks..."

# Lint — fail fast before generating artifacts, only when Go files are staged
if git diff --cached --name-only | grep -q '\.go$'; then
    echo "🔍  Running lint..."
    if ! make lint; then
        echo "❌  Lint failed. Fix errors before committing."
        exit 1
    fi
    echo "✅  Lint passed"
fi

# Generate NOTICE file with dependency licenses
echo "📄  Generating NOTICE file..."

# Check if go-licenses is installed
if ! command -v go-licenses >/dev/null 2>&1; then
    echo "❌  Error: go-licenses not installed."
    echo "    Install with: go install github.com/google/go-licenses/v2@latest"
    exit 1
fi

# Check if template file exists
if [ ! -f "notice.tpl" ]; then
    echo "❌  Error: notice.tpl template file not found."
    exit 1
fi

# Generate NOTICE file (replaces existing if present)
if go-licenses report . --template=notice.tpl --include_tests > NOTICE.tmp 2> /dev/null; then
    # Replace NOTICE file
    mv NOTICE.tmp NOTICE
    
    # Stage NOTICE for commit
    git add NOTICE
    
    echo "✅  NOTICE file updated and staged"
else
    echo "❌  Failed to generate NOTICE file"
    cat << 'HELP'
    
    Common issues:
    - Ensure you're in the project root directory
    - Check that go.mod exists and is valid
    - Run 'go mod download' if modules are missing
HELP
    rm -f NOTICE.tmp
    exit 1
fi

# Generate CLI documentation
if git diff --cached --name-only | grep -qE '^(cmd|internal/tools/docgen)/'; then
    echo "📚  Generating CLI documentation..."

    if go run internal/tools/docgen/main.go --out ./docs/cli --format markdown; then
        changed=$(git status --porcelain -- docs/cli | awk '{print $2}')
        if [ -n "$changed" ]; then
            echo "$changed" | xargs git add
        fi

        echo "✅  CLI documentation updated and staged"
    else
        echo "❌  Failed to generate CLI documentation"
        cat << 'HELP'

    Common issues:
    - Ensure you're in the project root directory
    - Check that internal/tools/docgen/main.go exists
    - Run 'go mod download' if modules are missing
HELP
        exit 1
    fi
fi

echo "✅  Finished pre-commit checks"